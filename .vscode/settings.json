{
  // Use the project venv for everything. The `snek`, `azsnek`, and `server`
  // packages are installed there (editable), so resolving imports just needs
  // the linter/analyzer to run against this interpreter.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Run Pylint from the venv (where pylint + the packages live), not a global
  // install — this is what fixes "Unable to import 'snek' / 'azsnek.net'".
  "pylint.interpreter": ["${workspaceFolder}/.venv/bin/python"],
  "pylint.importStrategy": "fromEnvironment",

  // Help Pylance/IntelliSense resolve the same source root.
  "python.analysis.extraPaths": ["${workspaceFolder}/python"],
  "python.analysis.typeCheckingMode": "basic",

  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["python/tests"]
}
