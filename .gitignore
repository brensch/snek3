# Rust (root workspace and the detached crates/snek-py workspace each have one)
target/

# Node
node_modules/
frontend/dist/

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Compiled extension (placed in the stub dir by `maturin develop`); the .pyi
# stubs and __init__.py in python/stubs/snek are source and ARE tracked.
*.so

# Training outputs
checkpoints/
!checkpoints/
checkpoints/*
# The tracked serving checkpoint baked into the API image (see deploy/).
!checkpoints/serving.safetensors
!checkpoints/serving.json
runs/
logs/
*.pt
*.pth.tar
*.onnx

# Editor / OS
.DS_Store
.idea/
# Track the shared VS Code/Cursor settings (venv interpreter), ignore the rest.
.vscode/*
!.vscode/settings.json

.env

# Local Battlesnake CLI scratch output.
local-vs-lan-game*.json
local-vs-lan-viewer.log
local-vs-lan-viewer.pid
game-seed*.json
